rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid (string), email (string), displayName (string), role (string), outlet_id (string, optional), lastOrderAt (timestamp, optional), createdAt (timestamp/string)
    //
    // Collection: outlets
    // Fields: id (string), name (string), description (string), image (string), rating (number), deliveryTime (string), cuisine (list), ownerId (string), location (string)
    //
    // Collection: outlets/{outletId}/menu
    // Fields: name (string), description (string), price (number), image (string), isVeg (bool), category (string)
    //
    // Collection: outlets/{outletId}/orders
    // Fields: userId (string), outlet_id (string), items (list), totalAmount (number), status (string), paymentStatus (string), riderId (string, optional), createdAt (timestamp)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "testingkit369@gmail.com" && request.auth.token.email_verified == true) ||
        hasRole('super_admin')
      );
    }

    function isAdmin() {
      return isSuperAdmin() || hasRole('admin');
    }

    function isOutletManager(outletId) {
      return hasRole('outlet_manager') && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.outlet_id == outletId;
    }

    function isRider() {
      return hasRole('rider');
    }

    // Validation Functions
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['customer', 'outlet_manager', 'rider', 'admin', 'super_admin'] &&
             (data.displayName == null || data.displayName is string) &&
             (data.outlet_id == null || data.outlet_id is string);
    }

    function isValidOutlet(data) {
      return data.keys().hasAll(['name', 'ownerId', 'location']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerId is string &&
             data.location is string && data.location.size() > 0 && data.location.size() < 500;
    }

    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'price', 'category']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);

      match /personal_data/{docId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
    }

    match /{path=**}/orders/{orderId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) ||
        isAdmin() ||
        isOutletManager(resource.data.outlet_id) ||
        isRider()
      );
    }

    match /outlets/{outletId} {
      allow read: if true;
      allow write: if (isAdmin() || isOutletManager(outletId)) && isValidOutlet(request.resource.data);
      
      match /menu/{itemId} {
        allow read: if true;
        allow write: if (isAdmin() || isOutletManager(outletId)) && isValidMenuItem(request.resource.data);
      }

      match /orders/{orderId} {
        allow read: if isAuthenticated() && (
          isOwner(resource.data.userId) ||
          isAdmin() ||
          isOutletManager(outletId) ||
          isRider()
        );
        
        allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.outlet_id == outletId;

        allow update: if isAuthenticated() && (
          isAdmin() ||
          isOutletManager(outletId) ||
          (isRider() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'riderLocation', 'riderId', 'riderName'])) ||
          (isOwner(resource.data.userId) && request.resource.data.status == 'cancelled' && resource.data.status == 'pending')
        );
      }
    }

    match /riders/{riderId}/live_location/{docId} {
      allow write: if isOwner(riderId) && isRider();
      allow read: if isAuthenticated();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
