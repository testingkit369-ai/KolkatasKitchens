# PhonePe Payment Gateway
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=TEST

# Security
HMAC_SECRET=
APP_URL=

# PhonePe Standard Checkout (Firebase Secrets)
# These should be set in Firebase Secret Manager, NOT in .env
PHONEPE_CLIENT_ID=your_client_id_here
PHONEPE_CLIENT_SECRET=your_client_secret_here
PHONEPE_CLIENT_VERSION=v1
PHONEPE_WEBHOOK_USER=your_webhook_user
PHONEPE_WEBHOOK_PASS=your_webhook_pass
